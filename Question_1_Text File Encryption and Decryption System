"""
HIT137 Assignment 2 – Question 1
File Encryption and Decryption Program

This program performs encryption and decryption on a text file using custom shift rules.

Workflow:
- Reads input from raw_text.txt
- Encrypts the content and writes to encrypted_text.txt
- Decrypts the encrypted file and writes to decrypted_text.txt
- Verifies that the decrypted file matches the original input

Encryption Rules:
- Only alphabetic characters are modified
- Digits, spaces, and special characters remain unchanged

Lowercase letters:
- a–m → shifted forward by (shift1 × shift2)
- n–z → shifted backward by (shift1 + shift2)

Uppercase letters:
- A–M → shifted backward by shift1
- N–Z → shifted forward by (shift2²)

Design Note:
The alphabet is divided into two 13-letter blocks (a–m and n–z, as well as A–M and N–Z).
Shifting is restricted within each block to maintain a one-to-one mapping, ensuring that
each encrypted character can be uniquely reversed during decryption. If shifting were applied
across the full 26-letter alphabet, different characters could map to the same result for
certain shift values, making accurate decryption impossible. By treating each half as a
separate 13-letter ring, the encryption remains fully reversible.
"""

from __future__ import annotations

from pathlib import Path

RING = 13


def _shift_in_block(ch: str, steps: int, forward: bool, is_lower: bool) -> str:
    """
    Shift a character within its 13-letter alphabet block.

    Lowercase blocks:
    - a-m
    - n-z

    Uppercase blocks:
    - A-M
    - N-Z
    """
    steps %= RING

    if is_lower:
        base = ord("a") if "a" <= ch <= "m" else ord("n")
    else:
        base = ord("A") if "A" <= ch <= "M" else ord("N")

    i = ord(ch) - base
    i = (i + steps) % RING if forward else (i - steps) % RING
    return chr(base + i)


def encrypt_one_char(ch: str, shift1: int, shift2: int) -> str:
    """Encrypt one character according to the assignment rules."""
    if "a" <= ch <= "m":
        return _shift_in_block(ch, shift1 * shift2, True, True)
    if "n" <= ch <= "z":
        return _shift_in_block(ch, shift1 + shift2, False, True)
    if "A" <= ch <= "M":
        return _shift_in_block(ch, shift1, False, False)
    if "N" <= ch <= "Z":
        return _shift_in_block(ch, shift2 * shift2, True, False)
    return ch


def decrypt_one_char(ch: str, shift1: int, shift2: int) -> str:
    """Decrypt one character according to the assignment rules."""
    if "a" <= ch <= "m":
        return _shift_in_block(ch, shift1 * shift2, False, True)
    if "n" <= ch <= "z":
        return _shift_in_block(ch, shift1 + shift2, True, True)
    if "A" <= ch <= "M":
        return _shift_in_block(ch, shift1, True, False)
    if "N" <= ch <= "Z":
        return _shift_in_block(ch, shift2 * shift2, False, False)
    return ch


def encrypt_text(text: str, shift1: int, shift2: int) -> str:
    """Encrypt a full string."""
    return "".join(encrypt_one_char(ch, shift1, shift2) for ch in text)


def decrypt_text(text: str, shift1: int, shift2: int) -> str:
    """Decrypt a full string."""
    return "".join(decrypt_one_char(ch, shift1, shift2) for ch in text)


def encrypt_file(shift1: int, shift2: int, folder: Path) -> None:
    """Read raw_text.txt and write encrypted_text.txt."""
    raw_path = folder / "raw_text.txt"
    out_path = folder / "encrypted_text.txt"

    try:
        raw = raw_path.read_text(encoding="utf-8")
        encrypted = encrypt_text(raw, shift1, shift2)
        out_path.write_text(encrypted, encoding="utf-8")
    except FileNotFoundError:
        print(f"Error: {raw_path.name} was not found.")
    except Exception as e:
        print(f"Error while encrypting: {e}")


def decrypt_file(shift1: int, shift2: int, folder: Path) -> None:
    """Read encrypted_text.txt and write decrypted_text.txt."""
    enc_path = folder / "encrypted_text.txt"
    out_path = folder / "decrypted_text.txt"

    try:
        enc = enc_path.read_text(encoding="utf-8")
        decrypted = decrypt_text(enc, shift1, shift2)
        out_path.write_text(decrypted, encoding="utf-8")
    except FileNotFoundError:
        print(f"Error: {enc_path.name} was not found.")
    except Exception as e:
        print(f"Error while decrypting: {e}")


def verify_decryption(folder: Path) -> None:
    """Compare raw_text.txt and decrypted_text.txt."""
    raw_path = folder / "raw_text.txt"
    dec_path = folder / "decrypted_text.txt"

    try:
        original = raw_path.read_text(encoding="utf-8")
        decrypted = dec_path.read_text(encoding="utf-8")

        if original == decrypted:
            print("Decryption successful: decrypted file matches the original.")
        else:
            print("Decryption FAILED: decrypted file does NOT match the original.")
    except FileNotFoundError as e:
        print(f"Error: Missing file - {e.filename}")
    except Exception as e:
        print(f"Error during verification: {e}")


def _ask_int(label: str) -> int:
    """Keep asking until the user enters an integer."""
    while True:
        try:
            return int(input(label).strip())
        except ValueError:
            print("That was not an integer, try again.")


def main() -> None:
    print("=== Question 1: file encrypt / decrypt ===\n")

    shift1 = _ask_int("Enter shift1 (integer): ")
    shift2 = _ask_int("Enter shift2 (integer): ")

    base = Path(__file__).resolve().parent

    encrypt_file(shift1, shift2, base)
    print("Wrote encrypted_text.txt (from raw_text.txt).")

    decrypt_file(shift1, shift2, base)
    print("Wrote decrypted_text.txt (from encrypted_text.txt).")

    verify_decryption(base)


if __name__ == "__main__":
    main()
